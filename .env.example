# Copie ce fichier en ".env" à la racine du projet, puis remplace la valeur par ta vraie clé.
# Ne commite jamais le fichier .env (il est dans .gitignore).

OPENAI_API_KEY=

# Optionnel : identifiant de sécurité OpenAI si ton compte l’exige.
# OPENAI_SAFETY_IDENTIFIER=

# Optionnel : port du serveur (défaut 8787).
# PORT=8787
